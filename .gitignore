# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
beamlens-*.tar

# Temporary files, for example, from tests.
/tmp/

# ElixirLS
/.elixir_ls/

# Claude Code session state — not project content
/.claude/

# Local environment overrides
.env

# Internal research/analysis notes — some reference third-party tools by
# name (competitor benchmark comparisons) and aren't meant to be committed
# or published. Kept locally only.
/docs/

# Real-world repos checked out for Phase 0 parity validation — these are
# full clones (with their own _build/) fetched for research/testing, not
# package fixtures. Never meant to be committed or published; the actual
# test fixtures are the small synthetic files alongside them.
/priv/fixtures/mongooseim/
/priv/fixtures/amoc-arsenal-xmpp/
/priv/fixtures/elixir/
